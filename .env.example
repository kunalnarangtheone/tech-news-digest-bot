# ================================
# Required Configuration
# ================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ================================
# Ollama Configuration (Local LLM)
# ================================

# Ollama base URL (default: local instance)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Ollama model to use
# Recommended: qwen2.5:7b (fast), qwen2.5:32b (better quality)
# Install with: ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b

# ================================
# LangChain Agent Configuration
# ================================

# Enable LangChain agent for intelligent research
USE_LANGCHAIN_AGENT=true

# ================================
# Neo4j Aura Configuration
# ================================
# Sign up at https://neo4j.com/cloud/aura/ for free instance
# Free tier: 200k nodes, 400k relationships

# Neo4j Aura instance connection
NEO4J_URI=neo4j+s://xxxxx.databases.neo4j.io
NEO4J_USER=your_instance_id
NEO4J_PASSWORD=your_generated_password
NEO4J_DATABASE=your_database_name

# Aura instance details (for reference)
AURA_INSTANCEID=your_instance_id
AURA_INSTANCENAME=Free instance

# ================================
# Embedding Configuration
# ================================

# Ollama embedding model for vector search
# Install with: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

# ================================
# Required Configuration
# ================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ================================
# Ollama Configuration (Local LLM)
# ================================

# Ollama base URL (default: local instance)
OLLAMA_BASE_URL=http://localhost:11434/v1

# Ollama model to use
# Recommended: qwen2.5:7b (fast), qwen2.5:32b (better quality)
# Install with: ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b

# ================================
# OpenClaw Integration (Recommended)
# ================================
# Provides research + LLM via GitHub Copilot (no API limits!)
# Setup: Install openclaw CLI and configure GitHub Copilot

# Enable/disable OpenClaw integration
OPENCLAW_ENABLED=true

# OpenClaw Gateway URL
OPENCLAW_GATEWAY_URL=http://localhost:18789

# Telegram channel for automated digests
TELEGRAM_CHANNEL_ID=@your_channel_username

# Telegram chat for alerts
TELEGRAM_ALERT_CHAT=your_user_id

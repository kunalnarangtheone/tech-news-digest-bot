# ================================
# Required Configuration
# ================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenRouter API Key (from https://openrouter.ai/)
OPENROUTER_API_KEY=your_openrouter_api_key

# ================================
# Optional Configuration
# ================================

# LLM Model (default: google/gemini-2.0-flash-exp:free)
# Free: google/gemini-2.0-flash-exp:free, google/gemma-4-26b-a4b-it:free
# Paid: anthropic/claude-3.5-sonnet, openai/gpt-4-turbo
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ================================
# OpenClaw Integration (Optional)
# ================================
# Enable advanced research with browser automation
# Setup: ./scripts/setup_openclaw.sh

# Enable/disable OpenClaw integration
OPENCLAW_ENABLED=true

# OpenClaw Gateway URL
OPENCLAW_GATEWAY_URL=http://localhost:3000

# Telegram channel for automated digests
TELEGRAM_CHANNEL_ID=@your_channel_username

# Telegram chat for alerts
TELEGRAM_ALERT_CHAT=your_user_id
